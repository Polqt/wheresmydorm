{
  "meta": {
    "name": "WheresMyDorm Website Design System Contract",
    "version": "1.0.0",
    "last_updated": "2026-03-22",
    "purpose": "Authoritative UI implementation guide for AI when creating new website features in this repository.",
    "scope": [
      "showcase/src/app/globals.css",
      "showcase/src/app/layout.tsx",
      "showcase/src/app/page.tsx",
      "design.json"
    ],
    "stack": {
      "framework": "Next.js App Router",
      "language": "TypeScript + React",
      "styling": "Tailwind CSS v4 with inline @theme CSS variables",
      "icons": "lucide-react",
      "fonts": "Geist + Geist Mono (display=swap)"
    }
  },
  "design_dna": {
    "brand_style": [
      "minimal",
      "modern SaaS",
      "friendly professional",
      "card-first composition",
      "soft rounded geometry",
      "high legibility"
    ],
    "visual_principles": [
      "Prefer clarity over decorative effects.",
      "Use blue ramp as the only dominant brand family.",
      "Keep large white or near-white breathing space in light layouts.",
      "Use rounded shapes consistently across controls and containers.",
      "Use subtle depth (sm/md/lg shadows) instead of heavy blur or glow."
    ],
    "content_tone": {
      "voice": "direct, helpful, trustworthy",
      "cta_style": "verb-first and specific",
      "headline_style": "short, bold, sentence case"
    }
  },
  "tokens": {
    "font": {
      "sans": "var(--font-geist-sans), Inter, system-ui, sans-serif",
      "mono": "var(--font-geist-mono), ui-monospace, monospace"
    },
    "color": {
      "brand_ramp": {
        "primary_100": "#B5CAFF",
        "primary_200": "#829AFF",
        "primary_300": "#5B6FD1",
        "primary_400": "#3746A3",
        "primary_500": "#1D2662"
      },
      "accents": {
        "accent_orange": "#EA580C",
        "accent_sand": "#FFF7ED",
        "accent_teal": "#0F766E"
      },
      "semantic_light": {
        "bg_page": "#FFFFFF",
        "bg_subtle": "#F5F7FF",
        "bg_card": "#FFFFFF",
        "text_primary": "#0F172A",
        "text_secondary": "#475569",
        "text_muted": "#64748B",
        "border_soft": "#E2E8F0",
        "border_strong": "#CBD5E1",
        "brand": "#5B6FD1",
        "brand_hover": "#3746A3",
        "brand_soft": "#B5CAFF",
        "success": "#0F766E",
        "warning": "#EA580C",
        "error": "#EF4444"
      },
      "semantic_dark_reference": {
        "bg_page": "#0B0F19",
        "bg_panel": "#111827",
        "bg_card": "#0F172A",
        "text_primary": "#F8FAFC",
        "text_secondary": "#CBD5E1",
        "text_muted": "#94A3B8",
        "border_soft": "#1E293B",
        "border_strong": "#334155",
        "brand": "#829AFF",
        "brand_hover": "#B5CAFF",
        "brand_soft": "#3746A3",
        "success": "#14B8A6",
        "warning": "#F97316",
        "error": "#F43F5E"
      }
    },
    "radius_px": {
      "xs": 8,
      "sm": 12,
      "md": 16,
      "lg": 20,
      "xl": 24,
      "pill": 9999
    },
    "shadow": {
      "sm": "0 1px 2px rgba(15, 23, 42, 0.06)",
      "md": "0 8px 24px rgba(15, 23, 42, 0.10)",
      "lg": "0 16px 40px rgba(15, 23, 42, 0.14)",
      "brand": "0 6px 20px rgba(91, 111, 209, 0.35)"
    },
    "motion": {
      "duration_ms": {
        "fast": 120,
        "base": 180,
        "slow": 260
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
        "enter": "cubic-bezier(0.16, 1, 0.3, 1)",
        "exit": "cubic-bezier(0.4, 0, 1, 1)"
      }
    },
    "spacing": {
      "base_unit": 4,
      "allowed_px": [4, 8, 12, 16, 20, 24, 32, 40, 48, 56, 64, 80, 96, 120]
    },
    "layout": {
      "breakpoints_px": {
        "sm": 480,
        "md": 768,
        "lg": 1024,
        "xl": 1280,
        "xxl": 1440
      },
      "container": {
        "max_width_px": 1200,
        "gutter_mobile_px": 20,
        "gutter_desktop_px": 40
      }
    }
  },
  "global_css_contract": {
    "body": {
      "background": "#FFFFFF",
      "text_color": "#0F172A",
      "font_family": "var(--font-sans)",
      "font_smoothing": "antialiased"
    },
    "focus_visible": {
      "outline": "2px solid #5B6FD1",
      "outline_offset": "2px",
      "border_radius": "4px"
    },
    "transitions": {
      "global_timing_function": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "reduced_motion": "Set animation and transition duration to 0.01ms when prefers-reduced-motion is reduce."
    }
  },
  "typography_system": {
    "font_usage": {
      "headings": "Geist/Inter/system sans",
      "body": "Geist/Inter/system sans",
      "code_or_token": "Geist Mono/monospace"
    },
    "scale": {
      "h1": { "size_px": 56, "weight": 700, "line_height": 1.05, "tracking_em": -0.02 },
      "h2": { "size_px": 44, "weight": 700, "line_height": 1.1, "tracking_em": -0.015 },
      "h3": { "size_px": 34, "weight": 600, "line_height": 1.15, "tracking_em": -0.01 },
      "h4": { "size_px": 28, "weight": 600, "line_height": 1.2, "tracking_em": 0 },
      "h5": { "size_px": 22, "weight": 600, "line_height": 1.25, "tracking_em": 0 },
      "title": { "size_px": 18, "weight": 600, "line_height": 1.3, "tracking_em": 0 },
      "body": { "size_px": 16, "weight": 400, "line_height": 1.6, "tracking_em": 0 },
      "small": { "size_px": 14, "weight": 400, "line_height": 1.45, "tracking_em": 0 },
      "caption": { "size_px": 12, "weight": 500, "line_height": 1.4, "tracking_em": 0.02 }
    },
    "rules": [
      "Use sentence case for labels and CTAs.",
      "Keep long-form text at 60-75 characters per line on desktop.",
      "Prefer text_secondary (#475569) and text_muted (#64748B) for body/supporting copy."
    ]
  },
  "page_structure": {
    "sticky_header": {
      "style": "white background, soft bottom border, subtle shadow, top=0 sticky, z-index 40",
      "container": "max-width 1200, horizontal padding 20/40"
    },
    "intro_band": {
      "style": "top-to-bottom gradient from bg_subtle to white, soft bottom border",
      "content": "version pill, large title, descriptive body copy"
    },
    "section_wrapper": {
      "vertical_padding_px": 64,
      "bottom_border": "1px solid #E2E8F0",
      "header_pattern": "component chip + section title"
    },
    "main_container": {
      "max_width_px": 1200,
      "horizontal_padding_mobile_px": 20,
      "horizontal_padding_desktop_px": 40
    },
    "footer": {
      "style": "bg_subtle with top border",
      "content": "brand mini mark, muted metadata, compact nav links"
    }
  },
  "component_system": {
    "button": {
      "shape": "rounded-full by default",
      "sizes": {
        "sm": { "height_px": 36, "padding_x_px": 16, "text": "12px medium" },
        "md": { "height_px": 44, "padding_x_px": 20, "text": "14px medium" },
        "lg": { "height_px": 52, "padding_x_px": 24, "text": "16px medium" },
        "icon": { "size_px": 44, "shape": "circle" }
      },
      "variants": {
        "primary_dark": { "bg": "#0F172A", "text": "#FFFFFF", "hover_bg": "#1E293B" },
        "primary_brand": { "bg": "#5B6FD1", "text": "#FFFFFF", "hover_bg": "#3746A3" },
        "outline": { "bg": "#FFFFFF", "border": "#CBD5E1", "text": "#0F172A", "hover_bg": "#F8FAFC", "hover_border": "#94A3B8" },
        "ghost_brand": { "bg": "#F5F7FF", "border": "#B5CAFF", "text": "#5B6FD1", "hover_bg": "#EEF1FF" },
        "danger": { "bg": "#EF4444", "text": "#FFFFFF", "hover_bg": "#DC2626" }
      },
      "states": {
        "hover": "color/border change within 180ms",
        "pressed": "active scale 0.98 where used",
        "disabled": "opacity 0.4 with not-allowed cursor"
      }
    },
    "form_controls": {
      "field_base": {
        "height_px": 44,
        "radius_px": 12,
        "border": "#E2E8F0",
        "bg": "#FFFFFF",
        "text": "#0F172A",
        "placeholder": "#94A3B8"
      },
      "focus": {
        "ring": "2px #5B6FD1 at 30% opacity",
        "border": "#5B6FD1"
      },
      "error": {
        "border": "#EF4444",
        "icon": "#EF4444",
        "helper_text": "#EF4444"
      },
      "disabled": {
        "bg": "#F8FAFC",
        "text": "#94A3B8",
        "label_opacity": 0.5
      },
      "supported_controls": [
        "text/email/password/tel input",
        "select with custom chevron",
        "textarea",
        "checkbox",
        "radio",
        "toggle switch",
        "range slider"
      ]
    },
    "cards": {
      "shell": {
        "bg": "#FFFFFF",
        "border": "#E2E8F0",
        "radius_px": 20,
        "shadow_default": "md",
        "shadow_hover": "lg for interactive cards"
      },
      "types": [
        "listing card",
        "feature card",
        "stat card",
        "editorial card",
        "profile card",
        "empty state card"
      ],
      "rules": [
        "Use left-aligned copy for utility cards.",
        "Keep card inner padding in 20-24px range.",
        "Prefer one prominent CTA per card."
      ]
    },
    "badges_and_chips": {
      "shape": "rounded-full",
      "text_size": "12px",
      "status_palette": {
        "available": { "bg": "#F0FDF4", "border": "#86EFAC", "text": "#0F766E" },
        "under_review": { "bg": "#FFF7ED", "border": "#FED7AA", "text": "#EA580C" },
        "unavailable": { "bg": "#FFF1F2", "border": "#FECDD3", "text": "#EF4444" },
        "featured": { "bg": "#F5F7FF", "border": "#B5CAFF", "text": "#5B6FD1" },
        "archived": { "bg": "#F8FAFC", "border": "#E2E8F0", "text": "#64748B" }
      }
    },
    "alerts_and_feedback": {
      "container": "rounded 16px, 16px padding, icon on left",
      "variants": {
        "info": { "bg": "#F5F7FF", "border": "#B5CAFF", "icon": "#5B6FD1" },
        "success": { "bg": "#F0FDF4", "border": "#86EFAC", "icon": "#0F766E" },
        "warning": { "bg": "#FFF7ED", "border": "#FED7AA", "icon": "#EA580C" },
        "error": { "bg": "#FFF1F2", "border": "#FECDD3", "icon": "#EF4444" },
        "toast_dark": { "bg": "#0F172A", "text": "#FFFFFF", "shadow": "lg", "aria_live": "polite" }
      }
    },
    "testimonial_card": {
      "required_elements": ["star rating", "quote", "avatar", "name", "affiliation"],
      "quote_style": "15px text, relaxed line-height, dominant visual weight",
      "rating_colors": {
        "active_star": "#F59E0B",
        "inactive_star": "#E2E8F0"
      }
    },
    "pricing_card": {
      "layout": "3-column desktop, stack on mobile",
      "recommended_tier": {
        "bg": "#0F172A",
        "text": "#FFFFFF",
        "border": "2px solid #5B6FD1",
        "badge": "Most popular"
      },
      "cta_rules": [
        "Recommended card CTA uses filled brand button with brand glow.",
        "Other tiers use outline CTA."
      ]
    },
    "accordion": {
      "row": "rounded 16px white shell with subtle border",
      "trigger_min_height_px": 52,
      "icon": "plus rotates 45deg when open",
      "motion": "open/close 180ms with max-height + opacity transition"
    },
    "stats_strip": {
      "shell": "dark charcoal rounded 24px container",
      "value": "30-36px bold white text",
      "label": "14px muted #94A3B8"
    },
    "table": {
      "shell": "rounded 20px white card with md shadow and soft border",
      "toolbar": "search field + filter/add actions",
      "header": "uppercase 12px headers on #F8FAFC",
      "row": "soft bottom borders + hover background #F8FAFC",
      "status_badges": "reuse badge status palette",
      "pagination": "compact 32px min button height"
    },
    "modal_dialog": {
      "backdrop": "bg-black/50 + backdrop-blur-sm",
      "shell": "white rounded 24px with lg shadow",
      "spacing": "24px internal padding",
      "actions": "pair of equal-width pill buttons",
      "types": ["standard dialog", "destructive confirm dialog"]
    },
    "navigation": {
      "top_nav": "white rounded 16px bar with border and sm shadow",
      "tabs": "segmented control pattern on #F5F7FF background",
      "sidebar": "56px wide shell, rounded 16px, item pills with active and destructive patterns",
      "breadcrumbs": "small text links + chevron separators"
    },
    "skeleton_loader": {
      "color": "#F5F7FF",
      "animation": "animate-pulse",
      "shapes": ["media block", "title line", "meta line", "chip placeholders", "button placeholder"]
    },
    "progress_loading": {
      "progress_track": "#F5F7FF",
      "progress_fill_colors": ["#5B6FD1", "#0F766E", "#EA580C"],
      "stepper": "8px circles with connected line segments",
      "spinners": "2px border spinner with brand top border"
    },
    "feature_grid": {
      "card_bg": "#F5F7FF",
      "icon_tile": "white tile with border and sm shadow",
      "layout": "1 col mobile, 2 col tablet, 3 col desktop"
    },
    "avatar_presence": {
      "avatar_style": "gradient circles with initials",
      "group_pattern": "negative horizontal stacking",
      "presence_dot": {
        "online": "#0F766E",
        "offline": "#94A3B8",
        "dot_size_px": 12
      }
    },
    "search": {
      "hero_search": "12px height controls inside subtle panel shell",
      "inline_search": "compact 36px rounded-full field",
      "supporting_chips": "small outline chips in brand color family"
    },
    "upload": {
      "dropzone": "2px dashed border, subtle blue panel, hover border intensifies to brand",
      "file_row": "14px rounded row with small icon tile, status indicator, remove action"
    },
    "hero_module": {
      "shell": "dark surface #0F172A, rounded 24px",
      "headline": "large white + blue accent line",
      "cta_pair": "primary brand + outline white",
      "proof_elements": ["live listings pill", "avatar mini group", "weekly signup metric"],
      "right_column": "mock device card with subtle blur/glass framing"
    }
  },
  "accessibility_and_ux_baseline": {
    "contrast": {
      "normal_text_min": "4.5:1",
      "large_text_min": "3:1"
    },
    "touch_target_min_px": 44,
    "must_have": [
      "visible labels for form fields",
      "aria-label on icon-only controls",
      "aria-invalid and aria-describedby for field errors",
      "aria-live polite for passive toast updates",
      "visible focus ring using brand color",
      "reduced-motion handling"
    ],
    "behavior": [
      "Provide immediate visual feedback on click/tap (<120ms).",
      "Use contextual and actionable error language.",
      "For empty states, always include one corrective next step CTA."
    ]
  },
  "ai_implementation_rules": {
    "strict_do": [
      "Reuse tokens from this file before introducing any new value.",
      "Use rounded geometry (12/16/20/24/pill) consistently.",
      "Keep one primary CTA per region and demote secondary actions.",
      "Use subtle shadow progression: sm for chrome, md for cards, lg for overlays.",
      "Default to white card shells on light surfaces."
    ],
    "strict_do_not": [
      "Do not introduce new saturated primary hues outside the blue ramp.",
      "Do not use sharp corner geometry unless matching an existing pattern.",
      "Do not use heavy blur/glass effects on standard content cards.",
      "Do not create dense dashboard-like spacing on marketing sections.",
      "Do not rely on color alone to convey status."
    ],
    "new_feature_recipe": [
      "Step 1: Pick closest existing component family from component_system.",
      "Step 2: Apply matching token set (color, radius, spacing, shadow, typography).",
      "Step 3: Validate interactive states (hover, focus, pressed, disabled).",
      "Step 4: Validate accessibility contract before shipping.",
      "Step 5: Keep copy and hierarchy aligned with brand tone."
    ]
  }
}
